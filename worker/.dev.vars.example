# Copy this file to .dev.vars (git-ignored) for local `wrangler dev` testing.
# Never commit real secrets.

# Cloudflare's documented always-pass Turnstile test keys — safe for local dev.
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Fine-grained GitHub PAT, scoped to a throwaway fork of winapps-site (NOT
# the production repo), with "Contents: Read and write" permission.
GITHUB_PAT=github_pat_replace_me
